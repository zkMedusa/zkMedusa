{
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=6144"
    }
  },
  "buildCommand": "npm run copy:noir-wasm && npm run copy:bb-wasm && npm run compile:circuit && npm run build:sdk && next build",
  "functions": {
    "app/api/passport/issue/route.ts": {
      "maxDuration": 300
    },
    "app/api/staking/cron/buyback/route.ts": {
      "maxDuration": 300
    },
    "app/api/staking/stats/route.ts": {
      "maxDuration": 60
    },
    "app/api/staking/position/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/partner/cron/refresh",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/staking/cron/buyback",
      "schedule": "*/30 * * * *"
    }
  ]
}
