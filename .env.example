# App URL (used in SDK docs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Passport payments (x402 — USDC on Solana)
NEXT_PUBLIC_PASSPORT_TREASURY_WALLET=YOUR_SOLANA_TREASURY_WALLET
PASSPORT_TREASURY_WALLET=YOUR_SOLANA_TREASURY_WALLET
NEXT_PUBLIC_PASSPORT_ISSUE_PRICE_USDC=0.50
# Facilitator — leave unset to auto-pick by network:
#   devnet  → https://x402.org/facilitator (no auth)
#   mainnet → https://api.cdp.coinbase.com/platform/v2/x402 (requires CDP keys below)
# Do NOT point devnet at the CDP URL without CDP_API_KEY_ID/SECRET.
X402_FACILITATOR_URL=
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
# Set true to mint without x402 while testing ZK proofs
PASSPORT_DEV_SKIP_PAYMENT=true

# Passport issuer signing keys (run: npm run passport:keys)
PASSPORT_ISSUER_SECRET_KEY=
PASSPORT_ISSUER_PUBLIC_KEY=

# ZK: @aztec/bb.js must match the Noir compiler version (see Aztec bb-versions.json).
# ZK: Vercel compiles the circuit on deploy (see vercel.json).
# For production on Vercel, set both to false.
# For local dev on Windows, keep these true until passport.json exists.
NEXT_PUBLIC_PASSPORT_DEV_MODE=true
PASSPORT_DEV_SKIP_ZK=true

# Partner SDK keys: campaignId:apiKey,campaignId:apiKey
MEDUSA_PARTNER_API_KEYS=my-presale-q3:sk_live_change_me
