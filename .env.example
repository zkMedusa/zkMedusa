NEXT_PUBLIC_APP_URL=http://localhost:3000

# Use mainnet-beta for production staking (Streamflow pools are on mainnet).
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

NEXT_PUBLIC_PASSPORT_TREASURY_WALLET=YOUR_SOLANA_TREASURY_WALLET
PASSPORT_TREASURY_WALLET=YOUR_SOLANA_TREASURY_WALLET
NEXT_PUBLIC_PASSPORT_ISSUE_PRICE_USDC=0.50

X402_FACILITATOR_URL=
PASSPORT_DEV_SKIP_PAYMENT=true

PASSPORT_ISSUER_SECRET_KEY=
PASSPORT_ISSUER_PUBLIC_KEY=

NEXT_PUBLIC_PASSPORT_DEV_MODE=true
PASSPORT_DEV_SKIP_ZK=true

MEDUSA_PARTNER_API_KEYS=my-presale-q3:sk_live_change_me

MEDUSA_CLAIM_CAMPAIGN_IDS=medusa-claim

# --- Partner token passports (ERC-20 gated, hidden /p/<slug> pages) ---
# Ethereum RPC for read-only balanceOf checks. A dedicated Alchemy/Infura URL is
# recommended; falls back to a public RPC if unset.
ETH_RPC_URL=
# Client-side RPC for the wagmi wallet connection (optional, read-only).
NEXT_PUBLIC_ETH_RPC_URL=
# Secret pepper for hashing holder addresses (HMAC). REQUIRED for partner pages.
# Use a long random string and keep it out of the database.
MEDUSA_PARTNER_PEPPER=
# AES-256 key (64 hex chars / 32 bytes) used to encrypt holder addresses at rest
# so the daily cron can re-check balances. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without it, addresses aren't stored and passports won't auto-refresh.
MEDUSA_PARTNER_ENCRYPTION_KEY=
# Secret required by the daily refresh cron. Vercel Cron sends it as a Bearer
# token automatically when set. Use a long random string.
CRON_SECRET=
# Optional WalletConnect project id to enable mobile/walletconnect wallets.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Per-partner holding threshold override (whole tokens). Lets you test small and
# ship at the real amount without a redeploy. Example: DeepBot test at 500.
MEDUSA_TOKEN_THRESHOLD_DEEPBOT=

# $MEDUSA SPL mint (Pump.fun). Used by the staking UI.
NEXT_PUBLIC_MEDUSA_TOKEN_MINT=

# Streamflow staking — four fixed-lock pools (mainnet). Stake/reward pools are public;
# top-up accounts receive buyback MEDUSA (Token-2022) for the daily fund delegate.
# Verify any time: npm run staking:pools
NEXT_PUBLIC_STREAMFLOW_STAKE_POOL_7D=
NEXT_PUBLIC_STREAMFLOW_STAKE_POOL_30D=
NEXT_PUBLIC_STREAMFLOW_STAKE_POOL_90D=
NEXT_PUBLIC_STREAMFLOW_STAKE_POOL_180D=
NEXT_PUBLIC_STREAMFLOW_REWARD_POOL_7D=
NEXT_PUBLIC_STREAMFLOW_REWARD_POOL_30D=
NEXT_PUBLIC_STREAMFLOW_REWARD_POOL_90D=
NEXT_PUBLIC_STREAMFLOW_REWARD_POOL_180D=
STREAMFLOW_TOPUP_7D=
STREAMFLOW_TOPUP_30D=
STREAMFLOW_TOPUP_90D=
STREAMFLOW_TOPUP_180D=

# Optional dedicated HTTP RPC for staking stats/position reads only (OOBE ok).
# Do not use for buyback — web3.js opens a websocket and OOBE returns 404.
MEDUSA_STAKING_RPC_URL=
# Buyback bot RPC (pump claim, Jupiter, top-ups). Use QuikNode HTTPS here.
# Falls back to NEXT_PUBLIC_SOLANA_RPC_URL when unset.
MEDUSA_BUYBACK_RPC_URL=
# Optional WSS URL if your provider uses a separate websocket endpoint.
MEDUSA_BUYBACK_WS_URL=
# Signs Jupiter swaps + Streamflow top-up transfers. Use the Pump.fun dev wallet
# (or a dedicated bot wallet funded from dev + treasury).
MEDUSA_BUYBACK_AUTHORITY_SECRET_KEY=
# Defaults to buyback authority pubkey when unset.
MEDUSA_DEV_WALLET=
# Receives 20% Pump.fun dev-fee slice + 50% passport reserve (optional).
MEDUSA_OPS_TREASURY_WALLET=
# Only needed when PASSPORT_TREASURY_WALLET != buyback authority.
MEDUSA_TREASURY_SECRET_KEY=
# Set false to pause live runs while keeping dry-run available.
MEDUSA_BUYBACK_ENABLED=true
MEDUSA_BUYBACK_MIN_SOL=0.05
MEDUSA_BUYBACK_SOL_RESERVE=0.02
MEDUSA_BUYBACK_MIN_USDC=1
MEDUSA_BUYBACK_SLIPPAGE_BPS=100
# Minimum accumulated Pump.fun dev fees before the bot claims (default 0.001 SOL).
MEDUSA_PUMP_CLAIM_MIN_SOL=0.001
# Optional Jupiter API key for higher rate limits (portal.jup.ag).
# Works without a key on lite-api.jup.ag; api.jup.ag requires x-api-key.
JUPITER_API_KEY=

# Partner API keys for whitelist + token roster export: partnerId:apiKey,...
# Example for DeepBot roster: deepbot:sk_live_change_me
# GET /api/partner/deepbot/token/roster with Authorization: Bearer sk_live_change_me

# Soulbound passport badge (MPL Core, non-transferable)
# Base58 (or JSON byte array) secret key of the wallet that mints + holds the
# update/freeze authority for badges. Keep it funded. Generate one with
# `npm run badge:collection` (it prints a key when none is set).
MEDUSA_BADGE_AUTHORITY_SECRET_KEY=
# Created once via `npm run badge:collection`.
MEDUSA_BADGE_COLLECTION=
NEXT_PUBLIC_MEDUSA_BADGE_COLLECTION=
# Optional dedicated RPC for minting (falls back to NEXT_PUBLIC_SOLANA_RPC_URL).
MEDUSA_BADGE_RPC_URL=
# Show the badge minting UI. Defaults to on when a public collection is set.
NEXT_PUBLIC_MEDUSA_BADGE_ENABLED=true
# Badge metadata `uri`. By default a short hosted URL is used when NEXT_PUBLIC_APP_URL
# is a public domain (keeps the image, no bucket). Set to true to force a fully
# on-chain, image-less data URI (no server dependency). The mint tx cannot embed
# the image either way — Solana caps transactions at 1232 bytes.
MEDUSA_BADGE_METADATA_ONCHAIN=false

# Persistent store (Upstash Redis / Vercel KV). When set, nullifiers, partner
# registrations, and badge records are stored here instead of the local
# filesystem (required on Vercel — /tmp is ephemeral). The Vercel Upstash
# integration injects these automatically. Native Upstash names also work
# (UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Telegram stake alerts (Option A: post-stake notify after on-chain verification).
# Create a bot via @BotFather, add it to your group/channel, then set chat id from getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_STAKE_CHAT_ID=
# Optional button URLs (must be public HTTPS — Telegram rejects localhost).
TELEGRAM_LINK_X=
TELEGRAM_LINK_STAKE=
TELEGRAM_LINK_WEBSITE=
# Image shown above the stake recap (must be a public HTTPS URL).
TELEGRAM_STAKE_IMAGE_URL=
