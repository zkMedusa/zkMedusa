{
  "name": "@medusa/passport-sdk",
  "version": "0.1.0",
  "description": "Verify and register Medusa Passports in third-party apps, presales, and whitelists.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://www.zkmedusa.com/docs",
