  },
  "dependencies": {
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "keywords": [
    "medusa",
    "passport",
    "solana",
    "zk",
    "whitelist",
    "presale"
