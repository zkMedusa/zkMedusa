{
  "name": "medusa",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:sdk && next build",
    "build:sdk": "npm run build --workspace=@zkmedusa/passport-sdk",
    "publish:sdk": "npm publish --workspace=@zkmedusa/passport-sdk --access public",
    "start": "next start",
    "lint": "next lint",
    "copy:noir-wasm": "node scripts/copy-noir-wasm.mjs",
    "copy:bb-wasm": "node scripts/copy-bb-wasm.mjs",
    "postinstall": "node scripts/copy-noir-wasm.mjs && node scripts/copy-bb-wasm.mjs",
    "compile:circuit": "node scripts/compile-circuit.mjs",
    "passport:keys": "node scripts/generate-issuer-keys.mjs",
    "badge:collection": "node scripts/create-badge-collection.mjs"
  },
  "dependencies": {
    "@aztec/bb.js": "5.0.0-nightly.20260522",
    "@dexterai/x402": "^3.17.0",
    "@metaplex-foundation/mpl-core": "^1.10.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@noble/hashes": "^1.8.0",
    "@noir-lang/acvm_js": "^1.0.0-beta.22",
    "@noir-lang/noir_js": "^1.0.0-beta.22",
    "@noir-lang/noir_wasm": "^1.0.0-beta.22",
    "@noir-lang/noirc_abi": "^1.0.0-beta.22",
    "@solana/kit": "^6.9.0",
    "@solana/sysvars": "^6.9.0",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "@upstash/redis": "^1.38.0",
    "bs58": "^6.0.0",
    "html-to-image": "^1.11.13",
    "next": "^15.1.0",
    "pako": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
